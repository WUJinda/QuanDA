{
  "name": "@quanda/electron",
  "version": "1.0.0",
  "description": "QuanDA 桌面应用 - Electron 主应用",
  "main": "dist/main.cjs",
  "author": {
    "name": "QuanDA Team"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"pnpm dev:vite\" \"pnpm dev:electron\"",
    "dev:vite": "vite dev",
    "dev:electron": "pnpm build:main && pnpm build:preload && pnpm build:resources && sleep 2 && concurrently -k -n main,preload,app -c yellow,magenta,cyan \"pnpm watch:main\" \"pnpm watch:preload\" \"electronmon .\"",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs --external:electron",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/preload.cjs --external:electron",
    "watch:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs --external:electron --watch=forever",
    "watch:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/preload.cjs --external:electron --watch=forever",
    "build:renderer": "vite build",
    "build:resources": "xcopy /E /I /Y resources dist\\resources",
    "build": "pnpm build:main && pnpm build:preload && pnpm build:renderer && pnpm build:resources",
    "start": "pnpm build && electron .",
    "typecheck": "tsc --noEmit",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@quanda/shared": "workspace:*",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "axios": "^1.6.5",
    "echarts": "^5.4.3",
    "vue-echarts": "^6.6.8",
    "element-plus": "^2.5.2",
    "@element-plus/icons-vue": "^2.3.1",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4",
    "esbuild": "^0.24.0",
    "sass-embedded": "^1.70.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.3",
    "vue-tsc": "^1.8.27"
  },
  "electronmon": {
    "patterns": ["dist/main.cjs", "dist/preload.cjs"],
    "logLevel": "verbose"
  },
  "build": {
    "extends": "electron-builder.yml"
  }
}
