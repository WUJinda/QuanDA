{
  "name": "quanda-desktop",
  "version": "1.0.0",
  "description": "QuanDA 量化交易桌面应用",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter='@quanda/electron' dev",
    "electron:dev": "pnpm --filter='@quanda/electron' dev",
    "electron:build": "pnpm --filter='@quanda/electron' build",
    "electron:start": "pnpm --filter='@quanda/electron' start",
    "build": "pnpm --filter='*' build",
    "typecheck": "pnpm --filter='*' typecheck",
    "dist": "pnpm --filter='@quanda/electron' dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
